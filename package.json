{
  "name": "pinion-emulator",
  "version": "0.1.0",
  "description": "Local PinionOS emulator for free agent development",
  "main": "dist/emulator.js",
  "bin": {
    "pinion-emulator": "dist/cli.js"
  },
  "license": "MIT",
  "files": [
    "dist/",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "ts-node src/cli.ts",
    "dev": "ts-node --watch src/emulator.ts",
    "build": "tsc -p tsconfig.json",
    "build:examples": "tsc -p tsconfig.examples.json",
    "mcp": "ts-node src/cli.ts mcp",
    "cli": "ts-node src/cli.ts",
    "prepublishOnly": "npm run build",
    "test": "node --require ts-node/register --test tests/routes/*.test.ts tests/integration/*.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "axios": "^1.8.0",
    "blessed": "^0.1.81",
    "blessed-contrib": "^4.11.0",
    "cors": "^2.8.5",
    "ethers": "^6.13.5",
    "express": "^4.21.2",
    "figlet": "^1.9.3",
    "pinion-os": "^0.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.25",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/figlet": "^1.7.0",
    "@types/node": "^22.10.2",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
